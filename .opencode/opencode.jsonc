{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {},
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "environment": {
        "NPM_CONFIG_CACHE": ".opencode/.npm-cache",
      },
      "enabled": true,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
